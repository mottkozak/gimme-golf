{
  "name": "gimme-golf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "build:mobile": "npm run build && npm run cap:sync",
    "sync:auth-scheme": "node scripts/sync-native-auth-scheme.mjs",
    "native:preflight": "node scripts/native-preflight.mjs",
    "native:toolchain:check": "node scripts/native-toolchain-check.mjs",
    "native:toolchain:check:android": "node scripts/native-toolchain-check.mjs android",
    "native:toolchain:check:ios": "node scripts/native-toolchain-check.mjs ios",
    "native:toolchain:gate": "node scripts/native-toolchain-gate.mjs",
    "native:toolchain:gate:android": "node scripts/native-toolchain-gate.mjs android",
    "native:toolchain:gate:ios": "node scripts/native-toolchain-gate.mjs ios",
    "cap:sync": "npm run sync:auth-scheme && cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "open:ios": "npm run sync:auth-scheme && cap open ios",
    "open:android": "npm run sync:auth-scheme && cap open android",
    "cap:icons": "npx @capacitor/assets generate",
    "lint": "eslint . --max-warnings=0",
    "check:maintainability": "node scripts/maintainability-check.mjs && node scripts/module-governance-check.mjs",
    "test": "npm run test:unit",
    "test:unit": "node --test src/**/*.test.ts",
    "test:unit:coverage": "c8 --reporter=text --reporter=lcov --reports-dir coverage/unit --check-coverage --branches 70 --functions 70 --lines 80 --statements 80 node --test src/**/*.test.ts",
    "test:component": "vitest run --config vitest.config.ts",
    "test:component:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:ci": "npm run lint && npm run typecheck && npm run test:unit:coverage && npm run test:component:coverage",
    "prebuild:android:release": "npm run native:toolchain:gate:android",
    "build:android:release": "cd android && ./gradlew clean :app:bundleRelease",
    "prebuild:ios:release": "npm run native:toolchain:gate:ios",
    "build:ios:release": "xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Release -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' CODE_SIGNING_ALLOWED=NO build",
    "preview": "vite preview",
    "test:e2e": "npm run test:e2e:web",
    "test:e2e:web": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:device": "maestro test maestro/flows/round-lifecycle-smoke.yaml maestro/flows/auth-deep-link-smoke.yaml",
    "test:e2e:ios:sim-smoke": "bash scripts/ios-simulator-smoke.sh",
    "test:e2e:ios:xcuitest-smoke": "bash scripts/ios-xcuitest-smoke.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@sentry/capacitor": "^3.1.0",
    "@sentry/react": "^10.40.0",
    "@supabase/supabase-js": "^2.99.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "c8": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
